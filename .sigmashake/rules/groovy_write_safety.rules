# groovy_write_safety.rules
# Technology: groovy | Capability: write

rule groovy-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "evaluate("
  MESSAGE "Blocked an unsafe pattern in groovy. Use the recommended best practices for 2025/2026."
}

rule groovy-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "GroovyShell"
  MESSAGE "You are using an outdated API for groovy. Please upgrade to the newer API."
}
